{
  "name": "@proofage/node",
  "version": "0.1.0",
  "description": "Node.js client for ProofAge API with HMAC authentication and webhook verification",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "proofage": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProofAge/node-client.git"
  },
  "homepage": "https://github.com/ProofAge/node-client#readme",
  "bugs": {
    "url": "https://github.com/ProofAge/node-client/issues"
  },
  "keywords": [
    "proofage",
    "age-verification",
    "kyc",
    "hmac"
  ],
  "publishConfig": {
    "access": "public"
  }
}
